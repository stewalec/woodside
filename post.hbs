{{!< default}}

{{#post}}

<header>
    <p class="meta muted"><time datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="D MMM YYYY"}}</time></p>
    <h1>{{title}}</h1>
    {{#if custom_excerpt}}<p class="subtitle muted">{{custom_excerpt}}</p>{{/if}}
</header>

{{content}}

{{/post}}